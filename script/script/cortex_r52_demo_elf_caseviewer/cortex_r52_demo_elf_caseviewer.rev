/comp = eori.l
/comp = muls
/comp = muls.w
/comp = mulu
/comp = mulu.w
/comp = nbcd
/comp = nbcd.b
/comp = or
/comp = or.b
/comp = or.w
/comp = or.l
/comp = ori
